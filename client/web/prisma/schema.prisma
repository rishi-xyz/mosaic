generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  apiKeys      ApiKey[]
  config       UserConfig?
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  keyHash    String
  keyPrefix  String
  name       String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  user       User      @relation(fields: [userId], references: [id])

  @@index([keyHash])
  @@index([userId])
}

model UserConfig {
  id        String   @id @default(uuid())
  userId    String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}
