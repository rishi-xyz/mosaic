# ── PostgreSQL (shared with web app) ─────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/mosaic

# ── MCP Server ────────────────────────────────────────────────────────
MCP_PORT=8001
# MCP_DISABLE_AUTH=false       # Set true for local dev without auth
# MCP_API_KEY=your-static-key  # Optional static key instead of DB lookup

# ── LLM (Ollama default, or OpenRouter) ──────────────────────────────
LLM_ENDPOINT=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b
EMBEDDING_ENDPOINT=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
STRUCTURED_OUTPUT_FRAMEWORK=baml
BAML_LLM_PROVIDER=openai
BAML_LLM_MODEL=llama3.2:3b
BAML_LLM_ENDPOINT=http://localhost:11434/v1
BAML_LLM_API_KEY=ollama

# Uncomment for OpenRouter instead of Ollama:
# OPENROUTER_API_KEY=sk-or-v1-...
# COGNEE_LLM_MODEL=openrouter/google/gemma-4-26b-a4b-it:free
# COGNEE_EMBEDDING_MODEL=openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free

# ── Neo4j (required for Cognee memory graph) ──────────────────────────
# Without these, Cognee falls back to local Kuzu (fine for dev, not prod)
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://host:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=your_password
GRAPH_DATABASE_NAME=neo4j
ENABLE_BACKEND_ACCESS_CONTROL=false
