# GitHub
GITHUB_TOKEN=github_pat_...
GITHUB_REPOSITORY=owner/repo

# Slack
SLACK_BOT_TOKEN=xoxb-...              # Optional — for real Slack API
SLACK_CHANNELS=engineering,general      # Comma-separated channel names
SLACK_USE_FIXTURES=true                 # Set true to use mock data instead of API

# Ollama (local — default, no key needed)
LLM_ENDPOINT=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b
EMBEDDING_ENDPOINT=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# OpenRouter (optional override — uncomment to use instead of Ollama)
# OPENROUTER_API_KEY=sk-or-v1-...
# COGNEE_LLM_MODEL=openrouter/google/gemma-4-26b-a4b-it:free
# COGNEE_EMBEDDING_MODEL=openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free

# BAML structured output (for local models — replaces Instructor)
STRUCTURED_OUTPUT_FRAMEWORK=baml
BAML_LLM_PROVIDER=openai
BAML_LLM_MODEL=llama3.2:3b
BAML_LLM_ENDPOINT=http://localhost:11434/v1
BAML_LLM_API_KEY=ollama

# Cognee internal (defaults from docs — no need to change)
# HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIMENSIONS=768
